rules_version = '2';

// ─────────────────────────────────────────────────────────────
// Firestore security rules for the QR Table Ordering System
// ─────────────────────────────────────────────────────────────
// Deploy with:  firebase deploy --only firestore:rules
//
// Model:
//   • menuItems  → public READ (customers browse the menu).
//                  WRITE requires an authenticated admin.
//   • orders     → public CREATE (a guest at a table places an order)
//                  and public READ (the kitchen board needs it without a
//                  login in this demo). UPDATE/DELETE require auth so only
//                  staff can advance order status.
//
// NOTE: This is intentionally permissive for a public, login-free demo.
// For production, tighten `orders` reads and place the kitchen behind auth.
// ─────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
  }
}
