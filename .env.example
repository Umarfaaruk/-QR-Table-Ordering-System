# ─────────────────────────────────────────────────────────────
# Firebase configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and replace the values below with the
# credentials from your own Firebase project:
#
#   Firebase Console → Project Settings → General → Your apps →
#   SDK setup and configuration → Config
#
# If you leave these blank, the app automatically runs in DEMO MODE
# with mock data + simulated real-time order updates. No Firebase
# project is required to explore the demo.
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — used by the hardcoded admin login fallback in demo mode.
# In a real deployment, create this user in Firebase Auth instead.
VITE_ADMIN_EMAIL=admin@cafespice.com
VITE_ADMIN_PASSWORD=demo1234
